# ===== Profile =====
# local: 免登录, docs 开启, 仅监听 127.0.0.1
# cloud: 完整鉴权, docs 关闭, 监听 0.0.0.0
# 不设置时自动检测: APP_ENV=beta|production -> cloud, 其他 -> local
# PROFILE 为启动别名，运行后会归一化为 APP_PROFILE；前端对应变量为 VITE_APP_PROFILE
APP_PROFILE=local

# ===== cloud 必须配置（缺少将拒绝启动） =====
# SECRET_KEY=<用 openssl rand -hex 32 生成>
# DEFAULT_ADMIN_PASSWORD=<用部署脚本自动生成或手动设置强密码>

# ===== Auth (仅 cloud 需关注, local 自动跳过) =====
# AUTH_DISABLED=true
# LOCAL_USERNAME=localuser
# LOCAL_DISPLAY_NAME=Local Researcher

# ===== Server =====
# HOST=127.0.0.1
# PORT=8000
# ENABLE_DOCS=true
# LOG_LEVEL=info

# ===== Fortran =====
# FORTRAN_EXECUTABLE=<自动检测 ../fortrancode/lm_opt2>
# FORTRAN_POSTPROCESS_EXECUTABLE=<自动检测 ../fortrancode/lm_postprocess>

# ===== 推荐配置 =====
# CORS_ORIGINS=["http://localhost:5173"]
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
# MAX_JOBS=1
# OMP_NUM_THREADS=0

# ===== 路径配置（如不配置，使用相对于 BACKEND_DIR 的默认值） =====
# UPLOAD_DIR=backend/temp
# RESULT_DIR=backend/result
# HDF5_DIR=backend/hdf5
# USER_RESULT_DIR=backend/userresult
# WORKING_DIR=backend/workdir
